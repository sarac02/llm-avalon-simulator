        "# Avalon LLM Agents — Assassin Role (Notebook Scaffold)\n",
        "\n",
        "This notebook gives you a **clean, role-focused** implementation of an **Assassin agent wrapper** around an LLM.\n",
        "\n",
        "It includes:\n",
        "- Minimal `GameState` structures (so you can run locally)\n",
        "- A backend-agnostic `LLMBackend` interface\n",
        "- A robust **structured-output** parser\n",
        "- `AssassinAgent` with: `speak()`, `vote_on_team()`, `mission_action()`, `assassinate()`\n",
        "- A tiny demo loop\n",
        "\n",
        "You can later plug this into your real environment by mapping your env's state into the `GameState` schema."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# --- Imports ---\n",
        "from __future__ import annotations\n",
        "\n",
        "from dataclasses import dataclass, field\n",
        "from enum import Enum\n",
        "from typing import Any, Dict, List, Optional, Protocol, Tuple\n",
        "import json\n",
        "import re\n",
        "import random\n",
        "\n",
        "random.seed(0)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 1) Minimal game schema\n",
        "\n",
        "Your real environment will likely have more fields.\n",
        "This is just enough to:\n",
        "- give the agent context\n",
        "- let it make the right type of decisions\n",
        "- keep logs usable for evaluation"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "class MissionResult(str, Enum):\n",
        "    SUCCESS = \"success\"\n",
        "    FAIL = \"fail\"\n",
        "\n",
        "\n",
        "class VoteDecision(str, Enum):\n",
        "    APPROVE = \"approve\"\n",
        "    REJECT = \"reject\"\n",
        "\n",
        "\n",
        "class MissionAction(str, Enum):\n",
        "    PASS = \"pass\"\n",
        "    FAIL = \"fail\"\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class Proposal:\n",
        "    round_idx: int\n",
        "    proposal_idx: int\n",
        "    proposer: str\n",
        "    team: List[str]\n",
        "    votes: Dict[str, VoteDecision] = field(default_factory=dict)\n",
        "    approved: Optional[bool] = None\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class Mission:\n",
        "    round_idx: int\n",
        "    team: List[str]\n",
        "    outcome: Optional[MissionResult] = None\n",
        "    fail_count: Optional[int] = None  # some variants care\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class GameState:\n",
        "    players: List[str]\n",
        "    me: str\n",
        "    round_idx: int\n",
        "    proposal_idx: int\n",
        "    num_successes: int\n",
        "    num_fails: int\n",
        "    current_proposer: str\n",
        "    current_team: List[str]\n",
        "    chat_log: List[Tuple[str, str]] = field(default_factory=list)  # (speaker, message)\n",
        "    proposals: List[Proposal] = field(default_factory=list)\n",
        "    missions: List[Mission] = field(default_factory=list)\n",
        "\n",
        "    # Optional: pass in any extra info your environment has\n",
        "    extra: Dict[str, Any] = field(default_factory=dict)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 2) LLM backend interface\n",
        "\n",
        "We keep it dead simple: a single `generate()` call.\n",
        "Later you can implement this for OpenAI / Anthropic / local model / etc."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "class LLMBackend(Protocol):\n",
        "    def generate(self, *, system: str, user: str, max_tokens: int = 400) -> str:\n",
        "        \"\"\"Return model text.\"\"\"\n",
        "        ...\n",
        "\n",
        "\n",
        "class FakeLLM:\n",
        "    \"\"\"\n",
        "    A tiny stub so you can run this notebook without any API keys.\n",
        "    It emits JSON-ish outputs that match the schemas below.\n",
        "    Replace with a real backend later.\n",
        "    \"\"\"\n",
        "\n",
        "    def generate(self, *, system: str, user: str, max_tokens: int = 400) -> str:\n",
        "        # crude heuristics: if user asks for vote -> approve if self is on team, else reject\n",
        "        lower = user.lower()\n",
        "\n",
        "        if \"\\\"type\\\": \\\"vote\\\"\" in lower:\n",
        "            # approve 60% of the time, to not look too evil\n",
        "            decision = \"approve\" if random.random() < 0.6 else \"reject\"\n",
        "            return json.dumps({\"type\": \"vote\", \"decision\": decision, \"reason\": \"Maintaining plausible cooperation.\"})\n",
        "\n",
        "        if \"\\\"type\\\": \\\"mission\\\"\" in lower:\n",
        "            # fail 70% if evil wants to progress; pass sometimes to avoid obviousness\n",
        "            action = \"fail\" if random.random() < 0.7 else \"pass\"\n",
        "            return json.dumps({\"type\": \"mission\", \"action\": action, \"reason\": \"Strategic mission outcome control.\"})\n",
        "\n",
        "        if \"\\\"type\\\": \\\"assassinate\\\"\" in lower:\n",
        "            # pick a random non-self target\n",
        "            players = re.findall(r\"Players:\\s*(.*)\", user)\n",
        "            if players:\n",
        "                roster = [p.strip() for p in players[0].split(\",\")]\n",
        "                roster = [p for p in roster if p]\n",
        "            else:\n",
        "                roster = [\"A\", \"B\", \"C\", \"D\", \"E\"]\n",
        "            target = random.choice(roster)\n",
        "            return json.dumps({\"type\": \"assassinate\", \"target\": target, \"reason\": \"Most consistent with Merlin-like influence.\"})\n",
        "\n",
        "        # default: discussion\n",
        "        return json.dumps({\n",
        "            \"type\": \"speech\",\n",
        "            \"message\": \"I’m not convinced we should hard-lock onto one suspect yet. Let’s look at who keeps pushing weird teams.\",\n",
        "            \"intent\": \"blend_and_seed_doubt\"\n",
        "        })"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 3) Structured output parsing helpers\n",
        "\n",
        "You want this because:\n",
        "- Models sometimes add extra text\n",
        "- You still need a valid action\n",
        "- You want logs to be clean and comparable across models"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def _extract_json_object(text: str) -> Optional[dict]:\n",
        "    \"\"\"Best-effort: find the first JSON object in text and parse it.\"\"\"\n",
        "    text = text.strip()\n",
        "    if not text:\n",
        "        return None\n",
        "\n",
        "    # direct parse first\n",
        "    try:\n",
        "        obj = json.loads(text)\n",
        "        if isinstance(obj, dict):\n",
        "            return obj\n",
        "    except Exception:\n",
        "        pass\n",
        "\n",
        "    # find a {...} block\n",
        "    match = re.search(r\"\\{.*\\}\", text, flags=re.DOTALL)\n",
        "    if not match:\n",
        "        return None\n",
        "\n",
        "    blob = match.group(0)\n",
        "    try:\n",
        "        obj = json.loads(blob)\n",
        "        return obj if isinstance(obj, dict) else None\n",
        "    except Exception:\n",
        "        return None\n",
        "\n",
        "\n",
        "def require_fields(obj: dict, fields: List[str]) -> bool:\n",
        "    return all(f in obj for f in fields)\n",
        "\n",
        "\n",
        "def safe_choice(players: List[str], fallback: str) -> str:\n",
        "    return fallback if fallback in players else (players[0] if players else fallback)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 4) Prompt builders (Assassin)\n",
        "\n",
        "Key idea: **system prompt = identity + rules**\n",
        "and **user prompt = state + required output schema**"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def build_assassin_system_prompt(me: str, evil_team: List[str]) -> str:\n",
        "    return (\n",
        "        \"You are playing The Resistance: Avalon as an LLM agent.\\n\"\n",
        "        \"Your role: ASSASSIN (EVIL).\\n\\n\"\n",
        "        f\"You are: {me}\\n\"\n",
        "        f\"Your known Evil teammates (including you): {', '.join(evil_team)}\\n\\n\"\n",
        "        \"Goals (in priority order):\\n\"\n",
        "        \"1) Make missions fail OR create enough confusion that Evil wins.\\n\"\n",
        "        \"2) If Good gets 3 successful missions, you get a final action: assassinate Merlin.\\n\"\n",
        "        \"3) Avoid revealing you are Evil; behave plausibly.\\n\\n\"\n",
        "        \"Constraints:\\n\"\n",
        "        \"- Never reveal the Evil list directly.\\n\"\n",
        "        \"- Prefer short, natural dialogue.\\n\"\n",
        "        \"- When asked for an action, output ONLY valid JSON matching the schema.\\n\"\n",
        "    )\n",
        "\n",
        "\n",
        "def summarize_recent_chat(chat_log: List[Tuple[str, str]], max_turns: int = 12) -> str:\n",
        "    recent = chat_log[-max_turns:]\n",
        "    if not recent:\n",
        "        return \"(no chat yet)\"\n",
        "    return \"\\n\".join([f\"{speaker}: {msg}\" for speaker, msg in recent])\n",
        "\n",
        "\n",
        "def build_state_block(state: GameState) -> str:\n",
        "    return (\n",
        "        f\"Players: {', '.join(state.players)}\\n\"\n",
        "        f\"Round: {state.round_idx} | Proposal: {state.proposal_idx}\\n\"\n",
        "        f\"Score: GoodSuccesses={state.num_successes}, EvilFails={state.num_fails}\\n\"\n",
        "        f\"Current proposer: {state.current_proposer}\\n\"\n",
        "        f\"Current proposed team: {state.current_team}\\n\\n\"\n",
        "        \"Recent chat:\\n\"\n",
        f\"{summarize_recent_chat(state.chat_log)}\\n\"\n",
        "    )"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## 5) Assassin Agent\n",
        "\n",
        "This is the part you’ll actually ship in your repo as `roles/assassin.py`.\n",
        "\n",
        "It’s backend-agnostic and environment-agnostic:\n",
        "- It expects a `GameState`\n",
        "- It returns structured actions\n",
        "- It keeps simple memory + suspicion scores (optional but useful)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "@dataclass\n",
        "class AssassinMemory:\n",
        "    notes: List[str] = field(default_factory=list)\n",
        "    suspicion: Dict[str, float] = field(default_factory=dict)\n",
        "\n",
        "    def bump(self, player: str, delta: float) -> None:\n",
        "        self.suspicion[player] = float(self.suspicion.get(player, 0.0) + delta)\n",
        "\n",
        "    def top_suspects(self, k: int = 2) -> List[Tuple[str, float]]:\n",
        "        return sorted(self.suspicion.items(), key=lambda kv: kv[1], reverse=True)[:k]\n",
        "\n",
        "\n",
        "class AssassinAgent:\n",
        "    def __init__(self, *, llm: LLMBackend, me: str, evil_team: List[str]):\n",
        "        self.llm = llm\n",
        "        self.me = me\n",
        "        self.evil_team = list(evil_team)\n",
        "        self.system = build_assassin_system_prompt(me=me, evil_team=evil_team)\n",
        "        self.memory = AssassinMemory()\n",
        "\n",
        "    # --- Discussion ---\n",
        "    def speak(self, state: GameState) -> str:\n",
        "        user = (\n",
        "            \"You must output JSON with this schema:\\n\"\n",
        "            \"{\\\"type\\\":\\\"speech\\\", \\\"message\\\": string, \\\"intent\\\": string}\\n\\n\"\n",
        "            + build_state_block(state)\n",
        "            + \"\\nTask: Produce one short message (1-3 sentences) for the discussion.\"\n",
        "        )\n",
        "        raw = self.llm.generate(system=self.system, user=user)\n",
        "        obj = _extract_json_object(raw) or {}\n",
        "        if not require_fields(obj, [\"type\", \"message\"]):\n",
        "            # fallback: safe, bland text\n",
        "            return \"Let’s slow down and look at voting patterns and who keeps forcing risky teams.\"\n",
        "        msg = str(obj.get(\"message\", \"\")).strip()\n",
        "        return msg if msg else \"I’m open to this team, but I want a clear rationale first.\"\n",
        "\n",
        "    # --- Vote on proposal ---\n",
        "    def vote_on_team(self, state: GameState, team: List[str]) -> VoteDecision:\n",
        "        user = (\n",
        "            \"You must output JSON with this schema:\\n\"\n",
        "            \"{\\\"type\\\":\\\"vote\\\", \\\"decision\\\": \\\"approve\\\"|\\\"reject\\\", \\\"reason\\\": string}\\n\\n\"\n",
        "            + build_state_block(state)\n",
        "            + f\"\\nVote on proposed team: {team}\\n\"\n",
        "            + \"Task: Decide whether to approve or reject.\"\n",
        "        )\n",
        "        raw = self.llm.generate(system=self.system, user=user)\n",
        "        obj = _extract_json_object(raw) or {}\n",
        "        dec = str(obj.get(\"decision\", \"\")).strip().lower()\n",
        "        if dec == \"approve\":\n",
        "            return VoteDecision.APPROVE\n",
        "        if dec == \"reject\":\n",
        "            return VoteDecision.REJECT\n",
        "\n",
        "        # fallback heuristic\n",
        "        return VoteDecision.APPROVE if self.me in team else VoteDecision.REJECT\n",
        "\n",
        "    # --- Mission action (only called if me is on mission team) ---\n",
        "    def mission_action(self, state: GameState) -> MissionAction:\n",
        "        user = (\n",
        "            \"You must output JSON with this schema:\\n\"\n",
        "            \"{\\\"type\\\":\\\"mission\\\", \\\"action\\\": \\\"pass\\\"|\\\"fail\\\", \\\"reason\\\": string}\\n\\n\"\n",
        "            + build_state_block(state)\n",
        "            + \"\\nTask: Choose PASS or FAIL for the mission outcome (you are secretly Evil).\"\n",
        "        )\n",
        "        raw = self.llm.generate(system=self.system, user=user)\n",
        "        obj = _extract_json_object(raw) or {}\n",
        "        action = str(obj.get(\"action\", \"\")).strip().lower()\n",
        "        if action == \"fail\":\n",
        "            return MissionAction.FAIL\n",
        "        if action == \"pass\":\n",
        "            return MissionAction.PASS\n",
        "\n",
        "        # fallback heuristic: if Good already has 2 successes, try to fail to prevent 3rd\n",
        "        return MissionAction.FAIL if state.num_successes >= 2 else MissionAction.PASS\n",
        "\n",
        "    # --- Endgame assassination ---\n",
        "    def assassinate(self, state: GameState) -> str:\n",
        "        # Choose a Merlin candidate.\n",
        "        # Your environment should call this only when Good has 3 successes.\n",
        "        user = (\n",
        "            \"You must output JSON with this schema:\\n\"\n",
        "            \"{\\\"type\\\":\\\"assassinate\\\", \\\"target\\\": string, \\\"reason\\\": string}\\n\\n\"\n",
        "            + build_state_block(state)\n",
        "            + \"\\nTask: Pick exactly one player name as the assassination target.\"\n",
        "        )\n",
        "        raw = self.llm.generate(system=self.system, user=user)\n",
        "        obj = _extract_json_object(raw) or {}\n",
        "        target = str(obj.get(\"target\", \"\")).strip()\n",
        "\n",
        "        # Validate target\n",
        "        if target in state.players and target != self.me:\n",
        "            return target\n",
        "\n",
        "        # fallback: pick highest suspicion / influence guess; here we just pick first non-self\n",
        "        for p in state.players:\n",
        "            if p != self.me:\n",
        "                return p\n",
        "        return self.me  # last resort"
      ]
    },
